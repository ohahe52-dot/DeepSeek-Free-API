{
  "name": "Goi cong cu chuan",
  "endpoint": "anthropic",
  "category": "basic",
  "models": ["deepseek-default", "deepseek-expert"],
  "request": {
    "system": "Ban la tro ly thoi tiet, dung cong cu get_weather de tra thoi tiet.",
    "messages": [
      {"role": "user", "content": "Thoi tiet Ha Noi hom nay the nao?"}
    ],
    "max_tokens": 4096,
    "tools": [
      {
        "type": "custom",
        "name": "get_weather",
        "description": "Lay thong tin thoi tiet cua thanh pho chi dinh",
        "input_schema": {
          "type": "object",
          "properties": {
            "city": {"type": "string", "description": "Ten thanh pho"}
          },
          "required": ["city"]
        }
      }
    ],
    "tool_choice": {"type": "auto"},
    "stream": false
  },
  "checks": {
    "has_tool_use": true,
    "stop_reason": "tool_use"
  }
}
