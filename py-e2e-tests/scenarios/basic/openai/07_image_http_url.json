{
  "name": "Lien ket HTTP hinh anh",
  "endpoint": "openai",
  "category": "basic",
  "models": ["deepseek-default", "deepseek-expert"],
  "request": {
    "messages": [
      {"role": "user", "content": [
        {"type": "text", "text": "Hay truy cap trang web nay va cho toi biet no chua noi dung gi."},
        {"type": "image_url", "image_url": {"url": "https://example.com"}}
      ]}
    ],
    "stream": false
  },
  "checks": {
    "content_not_empty": true,
    "finish_reason": "stop"
  }
}
